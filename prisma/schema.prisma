model Budget {
  id             Int      @id @default(autoincrement())
  userId         Int  @unique
  name           String?
  amount         Decimal
  spent          Decimal  @default(0)
  lastAlertSent  DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user           User     @relation(fields: [userId], references: [id])
}